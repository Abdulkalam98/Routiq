# App
ENVIRONMENT=development
APP_NAME=Routiq
APP_URL=https://routiq.io
API_URL=https://api.routiq.io
JWT_SECRET=change-me-to-a-random-secret

# Supabase (Free tier - 500MB PostgreSQL)
# Get from: https://supabase.com → Project Settings → Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql+asyncpg://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Upstash Redis (Free tier - 10K commands/day)
# Get from: https://upstash.com → Create Redis Database
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token
REDIS_URL=rediss://default:your-token@your-redis.upstash.io:6379

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
MISTRAL_API_KEY=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Exchange Rate
USD_TO_INR=84.0

# Vercel (Frontend)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
